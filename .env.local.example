# ─── Required ─────────────────────────────────────────────────────
# Secret for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# Shared secret between Next.js and Go API to authenticate internal requests.
# Must match INTERNAL_API_KEY in the Go backend Vercel project.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────
# Resend API key for sending password reset emails
# RESEND_API_KEY=

# Sender address for password reset emails
# EMAIL_FROM=Notes App <onboarding@resend.dev>

# ─── Dev Only ─────────────────────────────────────────────────────
# Base URL of the deployed Go backend (for local dev pointing to local Go server).
# In production on Vercel, leave this unset — VERCEL_URL is used automatically.
# GO_API_URL=http://localhost:4000
