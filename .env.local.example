# ─── Required ─────────────────────────────────────────────────────
# Shared secret between Next.js and Go API to authenticate internal requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=

# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/notes-app)
MONGODB_URI=

# Secret for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# ─── Optional ─────────────────────────────────────────────────────
# MongoDB database name (defaults to "notes-app")
# MONGODB_DB=notes-app

# Resend API key for sending password reset emails
# RESEND_API_KEY=

# Sender address for password reset emails
# EMAIL_FROM=Notes App <onboarding@resend.dev>

# ─── Dev Only (npm run dev + npm run dev:api) ─────────────────────
# Port for the standalone Go API dev server (defaults to 4000)
# GO_API_PORT=4000

# Base URL for the Go API dev server (defaults to http://localhost:4000)
# GO_API_BASE_URL=http://localhost:4000
