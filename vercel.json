{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/*.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "api/$1.go"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(?!api)(.*)",
      "dest": "/$1"
    }
  ]
}
